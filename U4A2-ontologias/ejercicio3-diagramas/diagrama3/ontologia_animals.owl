<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uag.mx/ontologias/animals#"
     xml:base="http://www.uag.mx/ontologias/animals"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

    <!-- ======================================== -->
    <!-- Declaración de la Ontología               -->
    <!-- ======================================== -->
    <owl:Ontology rdf:about="http://www.uag.mx/ontologias/animals">
        <rdfs:label xml:lang="es">Ontología de Animales y Mascotas</rdfs:label>
        <rdfs:comment xml:lang="es">Ontología con jerarquía Animal-Mammal-Dog, propiedades owns/hasPet/petOf, e individuos Robbie, Zeus y MrBurns. Basada en diagrama TBox/ABox.</rdfs:comment>
    </owl:Ontology>

    <!-- ======================================== -->
    <!-- TBox: Clases                              -->
    <!-- ======================================== -->

    <!-- Animal: clase con eyes = 2 -->
    <owl:Class rdf:about="#Animal">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#eyes"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Animal</rdfs:label>
    </owl:Class>

    <!-- Mammal: subclassOf Animal, legs = 4 -->
    <owl:Class rdf:about="#Mammal">
        <rdfs:subClassOf rdf:resource="#Animal"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#legs"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Mammal</rdfs:label>
    </owl:Class>

    <!-- Dog: subclassOf Mammal -->
    <owl:Class rdf:about="#Dog">
        <rdfs:subClassOf rdf:resource="#Mammal"/>
        <rdfs:label xml:lang="en">Dog</rdfs:label>
    </owl:Class>

    <!-- Human -->
    <owl:Class rdf:about="#Human">
        <rdfs:label xml:lang="en">Human</rdfs:label>
    </owl:Class>

    <!-- ======================================== -->
    <!-- TBox: Object Properties                   -->
    <!-- ======================================== -->

    <!-- owns: domain Human (type property) -->
    <owl:ObjectProperty rdf:about="#owns">
        <rdfs:domain rdf:resource="#Human"/>
        <rdfs:label xml:lang="en">owns</rdfs:label>
    </owl:ObjectProperty>

    <!-- hasPet: subProperty de owns, range Mammal -->
    <owl:ObjectProperty rdf:about="#hasPet">
        <rdfs:subPropertyOf rdf:resource="#owns"/>
        <rdfs:range rdf:resource="#Mammal"/>
        <rdfs:label xml:lang="en">hasPet</rdfs:label>
    </owl:ObjectProperty>

    <!-- petOf: inverseOf hasPet -->
    <owl:ObjectProperty rdf:about="#petOf">
        <owl:inverseOf rdf:resource="#hasPet"/>
        <rdfs:label xml:lang="en">petOf</rdfs:label>
    </owl:ObjectProperty>

    <!-- ======================================== -->
    <!-- TBox: Datatype Properties                 -->
    <!-- ======================================== -->

    <!-- eyes -->
    <owl:DatatypeProperty rdf:about="#eyes">
        <rdfs:domain rdf:resource="#Animal"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">eyes</rdfs:label>
    </owl:DatatypeProperty>

    <!-- legs -->
    <owl:DatatypeProperty rdf:about="#legs">
        <rdfs:domain rdf:resource="#Animal"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">legs</rdfs:label>
    </owl:DatatypeProperty>

    <!-- ======================================== -->
    <!-- ABox: Individuos (Instancias)             -->
    <!-- ======================================== -->

    <!-- Robbie: tipo Mammal (implícito por ser mascota / estar en contexto del diagrama) -->
    <owl:NamedIndividual rdf:about="#Robbie">
        <rdf:type rdf:resource="#Dog"/>
        <petOf rdf:resource="#Zeus"/>
        <rdfs:label xml:lang="en">Robbie</rdfs:label>
    </owl:NamedIndividual>

    <!-- Zeus: sameAs MrBurns -->
    <owl:NamedIndividual rdf:about="#Zeus">
        <rdf:type rdf:resource="#Human"/>
        <owns rdf:resource="#Robbie"/>
        <owl:sameAs rdf:resource="#MrBurns"/>
        <rdfs:label xml:lang="en">Zeus</rdfs:label>
    </owl:NamedIndividual>

    <!-- MrBurns: type Human, sameAs Zeus -->
    <owl:NamedIndividual rdf:about="#MrBurns">
        <rdf:type rdf:resource="#Human"/>
        <owl:sameAs rdf:resource="#Zeus"/>
        <rdfs:label xml:lang="en">MrBurns</rdfs:label>
    </owl:NamedIndividual>

</rdf:RDF>

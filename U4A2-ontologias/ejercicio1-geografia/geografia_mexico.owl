<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uag.mx/ontologias/geografia_mexico#"
     xml:base="http://www.uag.mx/ontologias/geografia_mexico"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:geo="http://www.uag.mx/ontologias/geografia_mexico#">

    <!-- ========================================== -->
    <!-- ONTOLOGIA DE GEOGRAFIA DE MEXICO           -->
    <!-- Universidad de Arizona Global Campus       -->
    <!-- Unidad 4: Ontologias y Web Semantica       -->
    <!-- ========================================== -->

    <owl:Ontology rdf:about="http://www.uag.mx/ontologias/geografia_mexico">
        <rdfs:label xml:lang="es">Ontologia de Geografia de Mexico</rdfs:label>
        <rdfs:comment xml:lang="es">Ontologia que modela la estructura geografica de Mexico, incluyendo paises, estados, ciudades, capitales y fronteras. Desarrollada para el curso de Razonamiento y Representacion del Conocimiento.</rdfs:comment>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>

    <!-- ========================================== -->
    <!-- CLASES PRINCIPALES                         -->
    <!-- ========================================== -->

    <!-- Clase raiz: Entidad Geografica -->
    <owl:Class rdf:about="#EntidadGeografica">
        <rdfs:label xml:lang="es">Entidad Geografica</rdfs:label>
        <rdfs:comment xml:lang="es">Clase abstracta que representa cualquier entidad con ubicacion geografica definida.</rdfs:comment>
    </owl:Class>

    <!-- Clase: Pais -->
    <owl:Class rdf:about="#Pais">
        <rdfs:subClassOf rdf:resource="#EntidadGeografica"/>
        <rdfs:label xml:lang="es">Pais</rdfs:label>
        <rdfs:comment xml:lang="es">Territorio soberano con gobierno propio, fronteras definidas y reconocimiento internacional.</rdfs:comment>
    </owl:Class>

    <!-- Clase: Estado (Entidad Federativa) -->
    <owl:Class rdf:about="#Estado">
        <rdfs:subClassOf rdf:resource="#EntidadGeografica"/>
        <rdfs:label xml:lang="es">Estado</rdfs:label>
        <rdfs:comment xml:lang="es">Entidad federativa que forma parte de un pais federal, con gobierno y territorio propios.</rdfs:comment>
    </owl:Class>

    <!-- Clase: Ciudad -->
    <owl:Class rdf:about="#Ciudad">
        <rdfs:subClassOf rdf:resource="#EntidadGeografica"/>
        <rdfs:label xml:lang="es">Ciudad</rdfs:label>
        <rdfs:comment xml:lang="es">Asentamiento urbano con poblacion significativa y servicios establecidos.</rdfs:comment>
    </owl:Class>

    <!-- Subclase: Capital Estatal -->
    <owl:Class rdf:about="#CapitalEstatal">
        <rdfs:subClassOf rdf:resource="#Ciudad"/>
        <rdfs:label xml:lang="es">Capital Estatal</rdfs:label>
        <rdfs:comment xml:lang="es">Ciudad que sirve como sede del gobierno de un estado.</rdfs:comment>
    </owl:Class>

    <!-- Subclase: Capital Nacional -->
    <owl:Class rdf:about="#CapitalNacional">
        <rdfs:subClassOf rdf:resource="#Ciudad"/>
        <rdfs:label xml:lang="es">Capital Nacional</rdfs:label>
        <rdfs:comment xml:lang="es">Ciudad que sirve como sede del gobierno federal de un pais.</rdfs:comment>
    </owl:Class>

    <!-- Clase: Frontera -->
    <owl:Class rdf:about="#Frontera">
        <rdfs:subClassOf rdf:resource="#EntidadGeografica"/>
        <rdfs:label xml:lang="es">Frontera</rdfs:label>
        <rdfs:comment xml:lang="es">Limite geografico entre dos entidades territoriales.</rdfs:comment>
    </owl:Class>

    <!-- Subclase: Frontera Internacional -->
    <owl:Class rdf:about="#FronteraInternacional">
        <rdfs:subClassOf rdf:resource="#Frontera"/>
        <rdfs:label xml:lang="es">Frontera Internacional</rdfs:label>
        <rdfs:comment xml:lang="es">Limite que separa territorios de diferentes paises.</rdfs:comment>
    </owl:Class>

    <!-- Subclase: Frontera Estatal -->
    <owl:Class rdf:about="#FronteraEstatal">
        <rdfs:subClassOf rdf:resource="#Frontera"/>
        <rdfs:label xml:lang="es">Frontera Estatal</rdfs:label>
        <rdfs:comment xml:lang="es">Limite que separa entidades federativas dentro de un mismo pais.</rdfs:comment>
    </owl:Class>

    <!-- Clase: Region Geografica -->
    <owl:Class rdf:about="#RegionGeografica">
        <rdfs:subClassOf rdf:resource="#EntidadGeografica"/>
        <rdfs:label xml:lang="es">Region Geografica</rdfs:label>
        <rdfs:comment xml:lang="es">Area que agrupa multiples entidades con caracteristicas comunes.</rdfs:comment>
    </owl:Class>

    <!-- Clase: Municipio -->
    <owl:Class rdf:about="#Municipio">
        <rdfs:subClassOf rdf:resource="#EntidadGeografica"/>
        <rdfs:label xml:lang="es">Municipio</rdfs:label>
        <rdfs:comment xml:lang="es">Division administrativa dentro de un estado.</rdfs:comment>
    </owl:Class>

    <!-- ========================================== -->
    <!-- PROPIEDADES DE OBJETO (Object Properties)  -->
    <!-- ========================================== -->

    <!-- Propiedad: perteneceA -->
    <owl:ObjectProperty rdf:about="#perteneceA">
        <rdfs:label xml:lang="es">pertenece a</rdfs:label>
        <rdfs:comment xml:lang="es">Indica que una entidad geografica es parte de otra entidad mayor.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="#EntidadGeografica"/>
    </owl:ObjectProperty>

    <!-- Propiedad inversa: contiene -->
    <owl:ObjectProperty rdf:about="#contiene">
        <rdfs:label xml:lang="es">contiene</rdfs:label>
        <rdfs:comment xml:lang="es">Indica que una entidad geografica incluye a otras entidades.</rdfs:comment>
        <owl:inverseOf rdf:resource="#perteneceA"/>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="#EntidadGeografica"/>
    </owl:ObjectProperty>

    <!-- Propiedad: esCapitalDe -->
    <owl:ObjectProperty rdf:about="#esCapitalDe">
        <rdfs:label xml:lang="es">es capital de</rdfs:label>
        <rdfs:comment xml:lang="es">Indica que una ciudad es la capital de un estado o pais.</rdfs:comment>
        <rdfs:domain rdf:resource="#Ciudad"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="#Estado"/>
                    <rdf:Description rdf:about="#Pais"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- Propiedad inversa: tieneCapital -->
    <owl:ObjectProperty rdf:about="#tieneCapital">
        <rdfs:label xml:lang="es">tiene capital</rdfs:label>
        <rdfs:comment xml:lang="es">Indica la capital de un estado o pais.</rdfs:comment>
        <owl:inverseOf rdf:resource="#esCapitalDe"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:ObjectProperty>

    <!-- Propiedad: limitaCon -->
    <owl:ObjectProperty rdf:about="#limitaCon">
        <rdfs:label xml:lang="es">limita con</rdfs:label>
        <rdfs:comment xml:lang="es">Indica que dos entidades geograficas comparten frontera.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="#EntidadGeografica"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    </owl:ObjectProperty>

    <!-- Propiedad: tieneFronteraCon -->
    <owl:ObjectProperty rdf:about="#tieneFronteraCon">
        <rdfs:label xml:lang="es">tiene frontera con</rdfs:label>
        <rdfs:comment xml:lang="es">Relaciona paises que comparten frontera internacional.</rdfs:comment>
        <rdfs:subPropertyOf rdf:resource="#limitaCon"/>
        <rdfs:domain rdf:resource="#Pais"/>
        <rdfs:range rdf:resource="#Pais"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    </owl:ObjectProperty>

    <!-- Propiedad: perteneceARegion -->
    <owl:ObjectProperty rdf:about="#perteneceARegion">
        <rdfs:label xml:lang="es">pertenece a region</rdfs:label>
        <rdfs:comment xml:lang="es">Indica la region geografica a la que pertenece un estado.</rdfs:comment>
        <rdfs:domain rdf:resource="#Estado"/>
        <rdfs:range rdf:resource="#RegionGeografica"/>
    </owl:ObjectProperty>

    <!-- Propiedad: tieneMunicipio -->
    <owl:ObjectProperty rdf:about="#tieneMunicipio">
        <rdfs:label xml:lang="es">tiene municipio</rdfs:label>
        <rdfs:comment xml:lang="es">Relaciona un estado con sus municipios.</rdfs:comment>
        <rdfs:domain rdf:resource="#Estado"/>
        <rdfs:range rdf:resource="#Municipio"/>
    </owl:ObjectProperty>

    <!-- Propiedad: tieneAccesoAMar -->
    <owl:ObjectProperty rdf:about="#tieneAccesoAMar">
        <rdfs:label xml:lang="es">tiene acceso a mar</rdfs:label>
        <rdfs:comment xml:lang="es">Indica si una entidad tiene costa maritima.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="#CuerpoDeAgua"/>
    </owl:ObjectProperty>

    <!-- Clase auxiliar: Cuerpo de Agua -->
    <owl:Class rdf:about="#CuerpoDeAgua">
        <rdfs:label xml:lang="es">Cuerpo de Agua</rdfs:label>
        <rdfs:comment xml:lang="es">Oceano, mar, golfo o lago.</rdfs:comment>
    </owl:Class>

    <!-- ========================================== -->
    <!-- PROPIEDADES DE DATOS (Data Properties)     -->
    <!-- ========================================== -->

    <!-- Propiedad: nombre -->
    <owl:DatatypeProperty rdf:about="#nombre">
        <rdfs:label xml:lang="es">nombre</rdfs:label>
        <rdfs:comment xml:lang="es">Nombre oficial de la entidad geografica.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    </owl:DatatypeProperty>

    <!-- Propiedad: poblacion -->
    <owl:DatatypeProperty rdf:about="#poblacion">
        <rdfs:label xml:lang="es">poblacion</rdfs:label>
        <rdfs:comment xml:lang="es">Numero de habitantes.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <!-- Propiedad: superficie -->
    <owl:DatatypeProperty rdf:about="#superficie">
        <rdfs:label xml:lang="es">superficie</rdfs:label>
        <rdfs:comment xml:lang="es">Area en kilometros cuadrados.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- Propiedad: codigoISO -->
    <owl:DatatypeProperty rdf:about="#codigoISO">
        <rdfs:label xml:lang="es">codigo ISO</rdfs:label>
        <rdfs:comment xml:lang="es">Codigo ISO 3166-2 del estado.</rdfs:comment>
        <rdfs:domain rdf:resource="#Estado"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- Propiedad: latitud -->
    <owl:DatatypeProperty rdf:about="#latitud">
        <rdfs:label xml:lang="es">latitud</rdfs:label>
        <rdfs:comment xml:lang="es">Coordenada de latitud en grados decimales.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- Propiedad: longitud -->
    <owl:DatatypeProperty rdf:about="#longitud">
        <rdfs:label xml:lang="es">longitud</rdfs:label>
        <rdfs:comment xml:lang="es">Coordenada de longitud en grados decimales.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- Propiedad: fechaFundacion -->
    <owl:DatatypeProperty rdf:about="#fechaFundacion">
        <rdfs:label xml:lang="es">fecha de fundacion</rdfs:label>
        <rdfs:comment xml:lang="es">Fecha en que fue fundada o establecida la entidad.</rdfs:comment>
        <rdfs:domain rdf:resource="#EntidadGeografica"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <!-- Propiedad: longitudFrontera -->
    <owl:DatatypeProperty rdf:about="#longitudFrontera">
        <rdfs:label xml:lang="es">longitud de frontera</rdfs:label>
        <rdfs:comment xml:lang="es">Longitud de la frontera en kilometros.</rdfs:comment>
        <rdfs:domain rdf:resource="#Frontera"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>

    <!-- ========================================== -->
    <!-- RESTRICCIONES Y AXIOMAS                    -->
    <!-- ========================================== -->

    <!-- Restriccion: Un Estado debe pertenecer exactamente a un Pais -->
    <owl:Class rdf:about="#Estado">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#perteneceA"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Pais"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Restriccion: Una Capital Estatal debe ser capital de exactamente un Estado -->
    <owl:Class rdf:about="#CapitalEstatal">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#esCapitalDe"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Estado"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Restriccion: Todo Estado tiene al menos una ciudad -->
    <owl:Class rdf:about="#Estado">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#contiene"/>
                <owl:someValuesFrom rdf:resource="#Ciudad"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Restriccion: Una Frontera Internacional conecta exactamente 2 paises -->
    <owl:Class rdf:about="#FronteraInternacional">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#conecta"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="#Pais"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Propiedad: conecta (para fronteras) -->
    <owl:ObjectProperty rdf:about="#conecta">
        <rdfs:label xml:lang="es">conecta</rdfs:label>
        <rdfs:comment xml:lang="es">Indica las entidades que una frontera separa/conecta.</rdfs:comment>
        <rdfs:domain rdf:resource="#Frontera"/>
        <rdfs:range rdf:resource="#EntidadGeografica"/>
    </owl:ObjectProperty>

    <!-- ========================================== -->
    <!-- INSTANCIAS: PAISES                         -->
    <!-- ========================================== -->

    <owl:NamedIndividual rdf:about="#Mexico">
        <rdf:type rdf:resource="#Pais"/>
        <geo:nombre>Estados Unidos Mexicanos</geo:nombre>
        <geo:poblacion rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">126014024</geo:poblacion>
        <geo:superficie rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1964375</geo:superficie>
        <geo:codigoISO>MX</geo:codigoISO>
        <geo:tieneFronteraCon rdf:resource="#EstadosUnidos"/>
        <geo:tieneFronteraCon rdf:resource="#Guatemala"/>
        <geo:tieneFronteraCon rdf:resource="#Belice"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#EstadosUnidos">
        <rdf:type rdf:resource="#Pais"/>
        <geo:nombre>Estados Unidos de America</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Guatemala">
        <rdf:type rdf:resource="#Pais"/>
        <geo:nombre>Republica de Guatemala</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Belice">
        <rdf:type rdf:resource="#Pais"/>
        <geo:nombre>Belice</geo:nombre>
    </owl:NamedIndividual>

    <!-- ========================================== -->
    <!-- INSTANCIAS: REGIONES DE MEXICO             -->
    <!-- ========================================== -->

    <owl:NamedIndividual rdf:about="#RegionNoroeste">
        <rdf:type rdf:resource="#RegionGeografica"/>
        <geo:nombre>Region Noroeste</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#RegionNoreste">
        <rdf:type rdf:resource="#RegionGeografica"/>
        <geo:nombre>Region Noreste</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#RegionOccidente">
        <rdf:type rdf:resource="#RegionGeografica"/>
        <geo:nombre>Region Occidente</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#RegionCentro">
        <rdf:type rdf:resource="#RegionGeografica"/>
        <geo:nombre>Region Centro</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#RegionSureste">
        <rdf:type rdf:resource="#RegionGeografica"/>
        <geo:nombre>Region Sureste</geo:nombre>
    </owl:NamedIndividual>

    <!-- ========================================== -->
    <!-- INSTANCIAS: CUERPOS DE AGUA                -->
    <!-- ========================================== -->

    <owl:NamedIndividual rdf:about="#OceanoPacifico">
        <rdf:type rdf:resource="#CuerpoDeAgua"/>
        <geo:nombre>Oceano Pacifico</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#GolfoDeMexico">
        <rdf:type rdf:resource="#CuerpoDeAgua"/>
        <geo:nombre>Golfo de Mexico</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#MarCaribe">
        <rdf:type rdf:resource="#CuerpoDeAgua"/>
        <geo:nombre>Mar Caribe</geo:nombre>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#GolfoDeCalfornia">
        <rdf:type rdf:resource="#CuerpoDeAgua"/>
        <geo:nombre>Golfo de California</geo:nombre>
    </owl:NamedIndividual>

    <!-- ========================================== -->
    <!-- INSTANCIAS: ESTADOS DE MEXICO (Muestra)    -->
    <!-- ========================================== -->

    <!-- Sonora -->
    <owl:NamedIndividual rdf:about="#Sonora">
        <rdf:type rdf:resource="#Estado"/>
        <geo:nombre>Sonora</geo:nombre>
        <geo:codigoISO>MX-SON</geo:codigoISO>
        <geo:poblacion rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2944840</geo:poblacion>
        <geo:superficie rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">179503</geo:superficie>
        <geo:perteneceA rdf:resource="#Mexico"/>
        <geo:perteneceARegion rdf:resource="#RegionNoroeste"/>
        <geo:limitaCon rdf:resource="#Chihuahua"/>
        <geo:limitaCon rdf:resource="#Sinaloa"/>
        <geo:limitaCon rdf:resource="#BajaCalifornia"/>
        <geo:tieneAccesoAMar rdf:resource="#GolfoDeCalfornia"/>
        <geo:tieneAccesoAMar rdf:resource="#OceanoPacifico"/>
        <geo:tieneCapital rdf:resource="#Hermosillo"/>
    </owl:NamedIndividual>

    <!-- Hermosillo (Capital de Sonora) -->
    <owl:NamedIndividual rdf:about="#Hermosillo">
        <rdf:type rdf:resource="#CapitalEstatal"/>
        <geo:nombre>Hermosillo</geo:nombre>
        <geo:poblacion rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">936263</geo:poblacion>
        <geo:latitud rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">29.0729</geo:latitud>
        <geo:longitud rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">-110.9559</geo:longitud>
        <geo:perteneceA rdf:resource="#Sonora"/>
        <geo:esCapitalDe rdf:resource="#Sonora"/>
    </owl:NamedIndividual>

    <!-- Chihuahua (Estado) -->
    <owl:NamedIndividual rdf:about="#Chihuahua">
        <rdf:type rdf:resource="#Estado"/>
        <geo:nombre>Chihuahua</geo:nombre>
        <geo:codigoISO>MX-CHH</geo:codigoISO>
        <geo:poblacion rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3741869</geo:poblacion>
        <geo:superficie rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">247455</geo:superficie>
        <geo:perteneceA rdf:resource="#Mexico"/>
        <geo:perteneceARegion rdf:resource="#RegionNoroeste"/>
        <geo:limitaCon rdf:resource="#Sonora"/>
        <geo:limitaCon rdf:resource="#Sinaloa"/>
        <geo:limitaCon rdf:resource="#Durango"/>
        <geo:limitaCon rdf:resource="#Coahuila"/>
        <geo:tieneCapital rdf:resource="#ChihuahuaCiudad"/>
    </owl:NamedIndividual>

    <!-- Chihuahua (Ciudad Capital) -->
    <owl:NamedIndividual rdf:about="#ChihuahuaCiudad">
        <rdf:type rdf:resource="#CapitalEstatal"/>
        <geo:nombre>Chihuahua</geo:nombre>
        <geo:poblacion rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">925762</geo:poblacion>
        <geo:latitud rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">28.6353</geo:latitud>
        <geo:longitud rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">-106.0889</geo:longitud>
        <geo:perteneceA rdf:resource="#Chihuahua"/>
        <geo:esCapitalDe rdf:resource="#Chihuahua"/>
    </owl:NamedIndividual>

    <!-- Nuevo Leon -->
    <owl:NamedIndividual rdf:about="#NuevoLeon">
        <rdf:type rdf:resource="#Estado"/>
        <geo:nombre>Nuevo Leon</geo:nombre>
        <geo:codigoISO>MX-NLE</geo:codigoISO>
        <geo:poblacion rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5784442</geo:poblacion>
        <geo:superficie rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">64220</geo:superficie>
        <geo:perteneceA rdf:resource="#Mexico"/>
        <geo:perteneceARegion rdf:resource="#RegionNoreste"/>
        <geo:limitaCon rdf:resource="#Coahuila"/>
        <geo:limitaCon rdf:resource="#Tamaulipas"/>
        <geo:limitaCon rdf:resource="#SanLuisPotosi"/>
        <geo:limitaCon rdf:resource="#Zacatecas"/>
        <geo:tieneCapital rdf:resource="#Monterrey"/>
    </owl:NamedIndividual>

    <!-- Monterrey (Capital de Nuevo Leon) -->
    <owl:NamedIndividual rdf:about="#Monterrey">
        <rdf:type rdf:resource="#CapitalEstatal"/>
        <geo:nombre>Monterrey</geo:nombre>
        <geo:poblacion rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1142994</geo:poblacion>
        <geo:latitud rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">25.6866</geo:latitud>
        <geo:longitud rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">-100.3161</geo:longitud>
        <geo:perteneceA rdf:resource="#NuevoLeon"/>
        <geo:esCapitalDe rdf:resource="#NuevoLeon"/>
    </owl:NamedIndividual>

    <!-- Jalisco -->
    <owl:NamedIndividual rdf:about="#Jalisco">
        <rdf:type rdf:resource="#Estado"/>
